rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Sin roles ni cuenta "activa": basta con tener sesión iniciada.
    function isSignedIn() {
      return request.auth != null;
    }

    // Cualquier usuario autenticado puede leer y escribir cualquier colección.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
